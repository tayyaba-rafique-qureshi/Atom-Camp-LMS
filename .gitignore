# ────────────────────────────────────────────────────────────────────────────
# atomcamp LMS - Git Ignore Configuration
# ────────────────────────────────────────────────────────────────────────────

# ═══════════════════════════════════════════════════════════════════════════
# Kiro AI Assistant
# ═══════════════════════════════════════════════════════════════════════════
.kiro/

# ═══════════════════════════════════════════════════════════════════════════
# Dependencies
# ═══════════════════════════════════════════════════════════════════════════
node_modules/
client/node_modules/
server/node_modules/

# Package lock files (optional - uncomment if you want to ignore them)
# package-lock.json
# client/package-lock.json
# server/package-lock.json

# ═══════════════════════════════════════════════════════════════════════════
# Environment Variables & Secrets
# ═══════════════════════════════════════════════════════════════════════════
.env
.env.local
.env.development
.env.production
server/.env
client/.env

# Keep .env.example files for reference
!.env.example
!server/.env.example
!client/.env.example

# ═══════════════════════════════════════════════════════════════════════════
# Build Output
# ═══════════════════════════════════════════════════════════════════════════
dist/
build/
client/dist/
client/build/
server/dist/
server/build/

# ═══════════════════════════════════════════════════════════════════════════
# Logs
# ═══════════════════════════════════════════════════════════════════════════
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ═══════════════════════════════════════════════════════════════════════════
# Editor & IDE
# ═══════════════════════════════════════════════════════════════════════════
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Keep VS Code settings if needed (uncomment to track)
# !.vscode/settings.json
# !.vscode/extensions.json

# ═══════════════════════════════════════════════════════════════════════════
# Testing & Coverage
# ═══════════════════════════════════════════════════════════════════════════
coverage/
.nyc_output/
*.lcov

# ═══════════════════════════════════════════════════════════════════════════
# Temporary Files
# ═══════════════════════════════════════════════════════════════════════════
*.tmp
*.temp
.cache/
.parcel-cache/
.vite/

# ═══════════════════════════════════════════════════════════════════════════
# Database
# ═══════════════════════════════════════════════════════════════════════════
*.sqlite
*.sqlite3
*.db

# MongoDB dumps
dump/
*.bson

# ═══════════════════════════════════════════════════════════════════════════
# OS Generated
# ═══════════════════════════════════════════════════════════════════════════
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ═══════════════════════════════════════════════════════════════════════════
# Misc
# ═══════════════════════════════════════════════════════════════════════════
*.pem
*.key
*.cert
.eslintcache
